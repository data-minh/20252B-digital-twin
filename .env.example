DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
MQTT_TOPIC="parking/frames"
MQTT_PUB_USERNAME="parking_pub"
MQTT_PUB_PASSWORD="change-me-pub"
MQTT_SUB_USERNAME="parking_sub"
